{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/icons/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "pokeapi",
      "urls": ["https://pokeapi.co/api/v2/**"],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "7d",
        "timeout": "10s",
        "strategy": "freshness"
      }
    },
    {
      "name": "pokemon-sprites",
      "urls": ["https://raw.githubusercontent.com/PokeAPI/sprites/**"],
      "cacheConfig": {
        "maxSize": 500,
        "maxAge": "30d",
        "timeout": "15s",
        "strategy": "performance"
      }
    }
  ]
}
